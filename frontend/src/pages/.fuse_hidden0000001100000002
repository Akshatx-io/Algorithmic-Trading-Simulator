import { useEffect, useMemo, useState } from "react";
import toast from "react-hot-toast";
import {
  Mail, CalendarDays, ShieldCheck, RefreshCw, LogOut, BadgeCheck,
  Wallet, Banknote, BarChart3, TrendingUp, TrendingDown, Settings, Hash,
} from "lucide-react";
import { useNavigate } from "react-router-dom";

import Card, { CardHeader, CardBody } from "../components/ui/Card";
import useAuth from "../hooks/useAuth";
import usePortfolio from "../hooks/usePortfolio";
import { fetchMe } from "../services/authService";
import { resetAccount } from "../services/portfolioService";

const money = (n) =>
  `$${Number(n || 0).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const pct = (n) => `${Number(n || 0) >= 0 ? "+" : ""}${Number(n || 0).toFixed(2)}%`;

function Stat({ icon, label, value, sub, tone = "brand" }) {
  const Icon = icon;
  const tint = { brand: "text-brand-400", up: "text-up", down: "text-down", gray: "text-gray-300" }[tone];
  return (
    <div className="rounded-2xl border border-line/70 bg-ink-900/60 p-4 transition hover:border-brand-500/30">
      <div className="flex items-center gap-2 text-gray-400">
        <Icon size={15} className={tint} />
        <p className="text-xs font-medium uppercase tracking-wide">{label}</p>
      </div>
      <p className="mt-2 tnum text-2xl font-bold text-white">{value}</p>
      {sub && <p className={`mt-0.5 tnum text-xs font-medium ${tint}`}>{sub}</p>}
    </div>
  );
}

function Row({ icon: Icon, label, value }) {
  return (
    <div className="flex items-center gap-3 border-b border-line/50 py-3 last:border-0">
      <span className="flex h-9 w-9 items-center justify-center rounded-lg bg-ink-700 text-brand-400">
        <Icon size={16} />
      </span>
      <p className="text-sm text-gray-400">{label}</p>
      <p className="ml-auto truncate text-sm font-medium text-white">{value}</p>
    </div>
  );
}

export default function PaperAccount() {
  const { user, logout } = useAuth();
  const navigate = useNavigate();
  const { portfolio, refresh } = usePortfolio();
  const [me, setMe] = useState(user);
  const [confirm, setConfirm] = useState(false);
  const [resetting, setResetting] = useState(false);

  useEffect(() => {
    let on = true;
    fetchMe().then((d) => on && setMe(d)).catch(() => {});
    return () => { on = false; };
  }, []);

  const memberSince = useMemo(() => {
    const d = me?.created_at ? new Date(me.created_at) : null;
    return d && !Number.isNaN(d.getTime())
      ? d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
      : "—";
  }, [me]);

  const username = me?.username || user?.username || "Trader";
  const initial = username.charAt(0).toUpperCase();
  const pnl = portfolio.total_pnl || 0;
  const pnlUp = pnl >= 0;

  const doReset = async () => {
    setResetting(true);
    try {
      await resetAccount();
      await refresh();
      toast.success("Paper account reset to starting balance");
      setConfirm(false);
    } catch {
      toast.error("Reset failed. Try again.");
    } finally {
      setResetting(false);
    }
  };

  return (
    <div className="mx-auto max-w-5xl space-y-6">
      {/* Hero */}
      <Card className="overflow-hidden">
        <div className="relative bg-brand-gradient/10" style={{ background: "linear-gradient(120deg, rgba(56,189,248,0.12), rgba(52,211,153,0.08))" }}>
          <div className="flex flex-col gap-4 p-6 sm:flex-row sm:items-center">
            <span className="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand-gradient text-2xl font-bold text-white shadow-glow">
              {initial}
            </span>
            <div className="min-w-0 flex-1">
              <div className="flex flex-wrap items-center gap-2">
                <h2 className="truncate text-xl font-bold text-white">{username}</h2>
                <span className="inline-flex items-center gap-1 rounded-full bg-brand-500/15 px-2.5 py-0.5 text-xs font-semibold text-brand-300 ring-1 ring-brand-500/30">
                  <BadgeCheck size={12} /> Paper Trading
                </span>
                <span className="inline-flex items-center gap-1 rounded-full bg-up/10 px-2.5 py-0.5 text-xs font-semibold text-up ring-1 ring-up/30">
                  <span className="h-1.5 w-1.5 rounded-full bg-up" /> Active
                </span>
              </div>
              <p className="mt-1 flex items-center gap-1.5 text-sm text-gray-400">
                <Mail size={13} /> {me?.email || "—"}
              </p>
            </div>
            <button
              onClick={() => navigate("/account")}
              className="inline-flex items-center gap-2 self-start rounded-xl border border-line bg-ink-800/80 px-3.5 py-2 text-sm font-medium text-gray-200 transition hover:border-brand-500/40 hover:text-white"
            >
              <Settings size={15} /> Settings
            </button>
          </div>
        </div>
      </Card>

      {/* Financials */}
      <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <Stat icon={Wallet} label="Total Equity" value={money(portfolio.total_equity)} sub="Cash + positions" tone="brand" />
        <Stat icon={Banknote} label="Buying Power" value={money(portfolio.cash_balance)} sub="Cash available" tone="gray" />
        <Stat icon={BarChart3} label="Invested" value={money(portfolio.market_value)} sub="Market value" tone="gray" />
        <Stat
          icon={pnlUp ? TrendingUp : TrendingDown}
          label="Total P&L"
          value={money(pnl)}
          sub={pct(portfolio.pnl_percentage)}
          tone={pnlUp ? "up" : "down"}
        />
      </div>

      <div className="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {/* Details */}
        <Card className="lg:col-span-2">
          <CardHeader title="Account Details" subtitle="Your paper trading profile" />
          <CardBody>
            <Row icon={Hash} label="Username" value={username} />
            <Row icon={Mail} label="Email" value={me?.email || "—"} />
            <Row icon={ShieldCheck} label="Account type" value="Paper (simulated)" />
            <Row icon={Banknote} label="Base currency" value="USD" />
            <Row icon={CalendarDays} label="Member since" value={memberSince} />
          </CardBody>
        </Card>

        {/* Actions */}
        <Card>
          <CardHeader title="Account Actions" />
          <CardBody className="space-y-3">
            <div className="rounded-xl border border-line/70 bg-ink-900/60 p-4">
              <p className="text-sm font-medium text-white">Reset paper account</p>
              <p className="mt-1 text-xs text-gray-400">
                Wipes all positions and trade history and restores your starting cash balance.
              </p>
              {!confirm ? (
                <button
                  onClick={() => setConfirm(true)}
                  className="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-line bg-ink-800 px-3 py-2 text-sm font-medium text-gray-200 transition hover:border-brand-500/40 hover:text-white"
                >
                  <RefreshCw size={15} /> Reset account
                </button>
              ) : (
                <div className="mt-3 flex gap-2">
                  <button
                    onClick={doReset}
                    disabled={resetting}
                    className="flex flex-1 items-center justify-center gap-2 rounded-lg bg-down/90 px-3 py-2 text-sm font-semibold text-white transition hover:bg-down disabled:opacity-50"
                  >
                    <RefreshCw size={15} className={resetting ? "animate-spin" : ""} />
                    {resetting ? "Resetting…" : "Confirm reset"}
                  </button>
                  <button
                    onClick={() => setConfirm(false)}
                    disabled={resetting}
                    className="rounded-lg border border-line px-3 py-2 text-sm text-gray-300 transition hover:text-white"
                  >
                    Cancel
                  </button>
                </div>
              )}
            </div>

            <button
              onClick={() => logout()}
              className="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-line bg-ink-800 px-3 py-2.5 text-sm font-medium text-gray-300 transition hover:border-down/40 hover:text-down"
            >
              <LogOut size={15} /> Log out
            </button>
          </CardBody>
        </Card>
      </div>
    </div>
  );
}
