# ============================================================================
# .dockerignore
# Keeps build context lean and prevents secrets / dev artifacts from leaking
# into production images. Audit finding 10.1.
# ============================================================================

# Version control
.git/
.gitignore
.gitattributes
.github/

# Python bytecode + caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.cover

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution
build/
dist/
*.egg-info/
*.egg

# Node (NEVER ship node_modules into the backend image — audit 10.1)
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*

# Environment + secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
secrets/

# Local databases
*.db
*.sqlite
*.sqlite3
hft.db

# ML model binaries (host externally / Git LFS — audit 5.10, 11)
*.h5
*.pkl
*.joblib
*.onnx
**/models/*.h5
**/models/*.pkl

# Logs
logs/
*.log
*.log.gz

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docs (rebuild target — not needed inside the image)
docs/_build/
site/

# Editor / OS junk
*~
.directory

# Documentation files only relevant on the repo side.
# NOTE: README.md and LICENSE MUST stay included — hatchling reads them via
# pyproject.toml's `readme = "README.md"` directive during `pip install -e .`.
AUDIT.md
ARCHITECTURE.md
ROADMAP.md
CONTRIBUTING.md
Makefile

# Tests are not included in the runtime image (they ship in CI only)
tests/
pytest.ini

# Misc
*.tmp
*.temp
*.bak
*.backup
